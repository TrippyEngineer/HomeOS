# ============================================================
# HomeOS — Environment Variables Reference
# ============================================================
# This file documents every env var used by the project.
# Copy the relevant sections into:
#   backend/.env   (for the FastAPI server)
#   frontend/.env  (for the React app)
#
# .env files are git-ignored. Never put real secrets here.
# ============================================================


# ── BACKEND (backend/.env) ───────────────────────────────────

# MongoDB connection string
MONGO_URL=mongodb://localhost:27017

# MongoDB database name
DB_NAME=homeos

# JWT signing secret — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<required — no default>

# Anthropic API key (primary LLM) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# xAI (Grok) API key (fallback LLM) — https://console.x.ai
# If Claude fails or is unconfigured, all LLM calls automatically fall back to Grok.
XAI_API_KEY=xai-...

# (Optional) Override the Claude model
# LLM_MODEL=claude-sonnet-4-5-20250929

# (Optional) Override the Grok fallback model
# GROK_MODEL=grok-3-mini

# (Optional) Comma-separated CORS origins. Defaults to * in dev.
# CORS_ORIGINS=https://yourdomain.com

# Swiggy Instamart MCP — https://partner.swiggy.com
# Leave blank to use mock demo mode.
SWIGGY_CLIENT_ID=
SWIGGY_CLIENT_SECRET=
SWIGGY_REDIRECT_URI=http://localhost:8000/api/swiggy/callback


# ── FRONTEND (frontend/.env) ─────────────────────────────────

# URL of the running backend API (no trailing slash)
REACT_APP_BACKEND_URL=http://localhost:8000


# ── TESTS (backend/.env or CI environment) ───────────────────

# Backend URL that tests hit. Defaults to http://localhost:8000
# REACT_APP_BACKEND_URL=http://localhost:8000
